rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'kraut9011@gmail.com' || request.auth.token.email == 'premzumble@gmail.com');
    }

    // Product images - public read, admin write
    match /products/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery images - public read, admin write
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Course images - public read, admin write
    match /courses/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Custom order uploads - owner can read, admin can write
    match /custom-orders/{fileId} {
      allow read: if isAdmin() || (request.auth != null && fileId.matches('.*_' + request.auth.token.email.replace('.', '_') + '.*'));
      allow write: if request.auth != null;
    }

    // Block all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
